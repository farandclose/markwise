{
  "name": "markwise",
  "version": "0.1.0",
  "description": "A human-agent review layer for markdown: anchored, structured notes stored in-file.",
  "type": "module",
  "bin": {
    "markwise": "./dist/cli.js"
  },
  "files": [
    "dist",
    "AGENT_PROMPT.md",
    "AUTHOR_PROMPT.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint:self": "node ./dist/cli.js lint sample.md",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
