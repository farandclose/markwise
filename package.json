{
  "name": "markwise",
  "version": "0.1.1",
  "description": "A human-agent review layer for markdown: anchored, structured notes stored in-file.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farandclose/markwise.git"
  },
  "homepage": "https://github.com/farandclose/markwise#readme",
  "bugs": {
    "url": "https://github.com/farandclose/markwise/issues"
  },
  "keywords": ["markdown", "review", "annotations", "comments", "cli", "agents", "previewer"],
  "author": "farandclose",
  "packageManager": "pnpm@10.29.3",
  "type": "module",
  "bin": {
    "markwise": "./dist/cli.js"
  },
  "files": [
    "dist",
    "AGENT_PROMPT.md",
    "AUTHOR_PROMPT.md",
    "SETUP_PROMPT.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-preview-assets.mjs",
    "prepare": "npm run build",
    "lint:self": "node ./dist/cli.js lint sample.md",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "smoke": "node scripts/smoke.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "markdown-it": "^14.2.0"
  }
}
